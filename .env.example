# DeepSeek API 配置（推荐国内用户使用）
# 去 https://platform.deepseek.com 注册，送免费额度
API_KEY=your_api_key_here
API_BASE=https://api.deepseek.com
MODEL=deepseek-chat

# 如果想用其他 AI 服务，修改上面三个值即可
# 比如 Moonshot:  API_BASE=https://api.moonshot.cn  MODEL=moonshot-v1-8k
# 比如 OpenAI:   API_BASE=https://api.openai.com     MODEL=gpt-3.5-turbo
